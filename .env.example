# OpenRouter API Configuration
# Get your API key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenRouter Model (optional - defaults to openai/gpt-4o-mini)
# Examples: openai/gpt-4-turbo, anthropic/claude-3-opus, mistral/mistral-large
OPENROUTER_MODEL=openai/gpt-4o-mini

# OpenRouter Base URL (optional - defaults to https://openrouter.ai/api/v1)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# HTTP Referer for OpenRouter (optional but recommended)
OPENROUTER_HTTP_REFERER=localhost

# Application Title (optional - defaults to CareerLens)
OPENROUTER_APP_TITLE=CareerLens

# RapidAPI Key
# Get your key at: https://rapidapi.com
RAPID_API_KEY=your_rapidapi_key_here

# Database URL
# SQLite example: sqlite:///./cv_matcher.db
# PostgreSQL example: postgresql://user:password@localhost:5432/cv_matcher
# MySQL example: mysql+pymysql://user:password@localhost:3306/cv_matcher
DATABASE_URL=sqlite:///./cv_matcher.db
